# --- Configuraciones Core ---
AIRFLOW_CORE_EXECUTOR=CeleryExecutor
# Genera una clave con: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_CORE_FERNET_KEY=>46_S7pW9x939S39as3sd939asS939as3sd939asS939aEQUIPO7
AIRFLOW_CORE_LOAD_EXAMPLES=False

# --- Base de Datos (PostgreSQL) ---
# Formato: postgresql+psycopg2://<user>:<password>@<host>:<port>/<db>
AIRFLOW_DATABASE_SQL_ALCHEMY_CONN=postgresql+psycopg2://coder-ra-c6:Riwi2026**@51.222.142.204:5432/lzheimer_airflow_db_2

# --- Celery (Broker y Backend) ---
# El Broker suele ser Redis o RabbitMQ. Si usas Redis en Docker, el host es el nombre del servicio.
# ---RABBITMQ (EL MENSAJERO) ---
# Formato: amqp://usuario:password@host:puerto/
# RabbitMQ usa el puerto 5672 por defecto.
AIRFLOW_CELERY_BROKER_URL=amqp://guest:guest@10.0.1.228:5672/

# El Result Backend en este caso apunta a tu Postgres
AIRFLOW_CELERY_RESULT_BACKEND=db+postgresql+psycopg2://coder-ra-c6:Riwi2026**@51.222.142.204:5432/lzheimer_airflow_db_2

# --- Configuraciones de Docker (Opcional pero recomendado) ---
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.0
_PIP_ADDITIONAL_REQUIREMENTS=psycopg2-binary